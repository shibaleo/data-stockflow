generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["data_accounting"]
}

// ============================================================
// マスタ系
// ============================================================

/// 勘定科目
model Account {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  code               String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code       String    /// [display] ユーザー向け科目コード（編集可）
  revision           Int       @default(1)
  valid_from         DateTime  @default(now()) @db.Timestamptz()
  valid_to           DateTime? @db.Timestamptz()
  created_by         String    @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz()
  name               String
  unit               String    @default("JPY")
  is_active          Boolean   @default(true)
  account_type       String    /// asset, liability, equity, revenue, expense
  sign               Int       /// +1=貸方正, -1=借方正
  parent_account_code String?  /// → account.code [identity]

  @@unique([tenant_id, code, revision])
  @@map("account")
  @@schema("data_accounting")
}

/// タグ（汎用分類）
model Tag {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  code         String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code String    /// [display] 編集可
  revision     Int       @default(1)
  valid_from   DateTime  @default(now()) @db.Timestamptz()
  valid_to     DateTime? @db.Timestamptz()
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz()
  name         String
  tag_type     String    /// 分類軸: project, cost_center, product 等
  is_active    Boolean   @default(true)

  @@unique([tenant_id, code, revision])
  @@map("tag")
  @@schema("data_accounting")
}

/// 会計期間
model FiscalPeriod {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  code         String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code String    /// [display] 編集可
  revision     Int       @default(1)
  valid_from   DateTime  @default(now()) @db.Timestamptz()
  valid_to     DateTime? @db.Timestamptz()
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz()
  fiscal_year  Int
  period_no    Int       /// 1〜12, 13=決算整理期間
  start_date   DateTime  @db.Timestamptz()
  end_date     DateTime  @db.Timestamptz()
  status       String    @default("open") /// open, closed, finalized

  @@unique([tenant_id, code, revision])
  @@map("fiscal_period")
  @@schema("data_accounting")
}

/// 部門
model Department {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String    @db.Uuid
  code                   String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code           String    /// [display] 編集可
  revision               Int       @default(1)
  valid_from             DateTime  @default(now()) @db.Timestamptz()
  valid_to               DateTime? @db.Timestamptz()
  created_by             String    @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz()
  name                   String
  parent_department_code String?   /// → department.code [identity]
  department_type        String?   /// statutory, management
  is_active              Boolean   @default(true)

  @@unique([tenant_id, code, revision])
  @@map("department")
  @@schema("data_accounting")
}

/// 消費税区分（グローバル、tenant_id なし）
model TaxClass {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code    String    /// [display] 編集可
  revision        Int       @default(1)
  valid_from      DateTime  @default(now()) @db.Timestamptz()
  valid_to        DateTime? @db.Timestamptz()
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz()
  name            String
  is_active       Boolean   @default(true)
  direction       String?   /// purchase, sale
  is_taxable      Boolean   @default(true)
  deduction_ratio Decimal?  @db.Decimal(5, 4)
  invoice_type    String?   /// qualified, transitional_80, transitional_50, none

  @@unique([code, revision])
  @@map("tax_class")
  @@schema("data_accounting")
}

/// 取引先
model Counterparty {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                String    @db.Uuid
  code                     String    @default(dbgenerated("gen_random_uuid()::text")) /// [identity] システム自動生成・不変
  display_code             String    /// [display] 編集可
  revision                 Int       @default(1)
  valid_from               DateTime  @default(now()) @db.Timestamptz()
  valid_to                 DateTime? @db.Timestamptz()
  created_by               String    @db.Uuid
  created_at               DateTime  @default(now()) @db.Timestamptz()
  name                     String
  is_active                Boolean   @default(true)
  qualified_invoice_number String?
  is_qualified_issuer      Boolean   @default(false)

  @@unique([tenant_id, code, revision])
  @@map("counterparty")
  @@schema("data_accounting")
}

/// テナント設定
model TenantSetting {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  revision     Int       @default(1)
  valid_from   DateTime  @default(now()) @db.Timestamptz()
  valid_to     DateTime? @db.Timestamptz()
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz()
  locked_until DateTime? @db.Timestamptz()

  @@unique([tenant_id, revision])
  @@map("tenant_setting")
  @@schema("data_accounting")
}

/// カテゴリ→科目マッピング
model AccountMapping {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  source_system String
  source_field  String
  source_value  String
  side          String    /// debit, credit
  revision      Int       @default(1)
  valid_from    DateTime  @default(now()) @db.Timestamptz()
  valid_to      DateTime? @db.Timestamptz()
  created_by    String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz()
  is_active     Boolean   @default(true)
  account_code  String    /// → account.code [identity]

  @@unique([tenant_id, source_system, source_field, source_value, side, revision])
  @@map("account_mapping")
  @@schema("data_accounting")
}

/// 決済手段→科目マッピング
model PaymentMapping {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id      String    @db.Uuid
  source_system  String
  payment_method String
  revision       Int       @default(1)
  valid_from     DateTime  @default(now()) @db.Timestamptz()
  valid_to       DateTime? @db.Timestamptz()
  created_by     String    @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz()
  is_active      Boolean   @default(true)
  account_code   String    /// → account.code [identity]

  @@unique([tenant_id, source_system, payment_method, revision])
  @@map("payment_mapping")
  @@schema("data_accounting")
}

// ============================================================
// ユーザーマッピング
// ============================================================

/// 外部IdP ↔ テナントユーザー マッピング
model TenantUser {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_id String   @unique /// 外部IdPユーザーID (e.g. Clerk "user_2abc...")
  tenant_id   String   @db.Uuid
  user_id     String   @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  role        String   @default("user") /// platform, tenant, admin, user
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@map("tenant_user")
  @@schema("data_accounting")
}

// ============================================================
// 監査ログ
// ============================================================

/// 監査ログ（全API操作を記録。INSERT-only、削除不可）
model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String?  @db.Uuid /// NULL for platform-level ops (tax_class)
  user_id     String   @db.Uuid
  user_role   String   /// platform, audit, tenant, admin, user
  action      String   /// create, update, deactivate, restore, reverse, close, reopen
  entity_type String   /// account, journal, fiscal_period, etc.
  entity_code String   /// code or idempotency_code of the affected entity
  revision    Int?     /// resulting revision number (if applicable)
  detail      String?  @db.Text /// JSON payload or description of the change
  source_ip   String?  /// client IP address
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([tenant_id, created_at])
  @@index([entity_type, entity_code])
  @@map("audit_log")
  @@schema("data_accounting")
}

// ============================================================
// トランザクション系
// ============================================================

/// 論理仕訳ヘッダ
model JournalHeader {
  idempotency_code   String    @id /// [identity] source:id 形式
  tenant_id          String    @db.Uuid
  voucher_code       String?   /// [display] 伝票番号
  fiscal_period_code String    /// → fiscal_period.code [identity]
  created_by         String    @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz()

  journals    Journal[]
  attachments JournalAttachment[]

  @@unique([tenant_id, fiscal_period_code, voucher_code])
  @@map("journal_header")
  @@schema("data_accounting")
}

/// 仕訳 revision
model Journal {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  idempotency_code String
  revision         Int      @default(1)
  is_active        Boolean  @default(true)
  posted_date      DateTime @default(dbgenerated("(now()::date)::timestamptz")) @db.Timestamptz()
  journal_type     String   @default("normal")  /// normal, closing, prior_adj, auto
  slip_category    String   @default("ordinary") /// ordinary, transfer, receipt, payment
  adjustment_flag  String   @default("none")     /// none, monthly_adj, year_end_adj
  description      String?
  source_system    String?
  created_by       String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz()

  header JournalHeader @relation(fields: [idempotency_code], references: [idempotency_code])
  lines  JournalLine[]
  tags   JournalTag[]

  @@unique([idempotency_code, revision])
  @@map("journal")
  @@schema("data_accounting")
}

/// 仕訳行
model JournalLine {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String   @db.Uuid
  journal_id        String   @db.Uuid
  line_group        Int
  side              String   /// debit, credit（表示用）
  account_code      String   /// → account.code [identity]
  department_code   String?  /// → department.code [identity]
  counterparty_code String?  /// → counterparty.code [identity]
  tax_class_code    String?  /// → tax_class.code [identity]
  tax_rate          Decimal? @db.Decimal(5, 4)
  is_reduced        Boolean?
  amount            Decimal  @db.Decimal(15, 0) /// 符号付き: 貸方=正, 借方=負
  description       String?

  journal Journal @relation(fields: [journal_id], references: [id])

  @@map("journal_line")
  @@schema("data_accounting")
}

/// 仕訳タグ（N:N）
model JournalTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String   @db.Uuid
  journal_id String   @db.Uuid
  tag_code   String   /// → tag.code [identity]
  created_by String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz()

  journal Journal @relation(fields: [journal_id], references: [id])

  @@map("journal_tag")
  @@schema("data_accounting")
}

/// 証憑（削除不可）
model JournalAttachment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String   @db.Uuid
  idempotency_code String
  file_name        String
  file_path        String
  mime_type        String?
  created_by       String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz()

  header JournalHeader @relation(fields: [idempotency_code], references: [idempotency_code])

  @@map("journal_attachment")
  @@schema("data_accounting")
}
